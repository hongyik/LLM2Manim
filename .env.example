# Copy this file to .env and fill in your API keys.
# You only need the key(s) for the provider(s) you use in llm_config.json.

DEEPSEEK_API_KEY=sk-...
GPT4_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default LLM provider globally
# LLM_PROVIDER=deepseek

# Optional: render quality — l (480p) · m (720p) · h (1080p) · p · k (4K)
# MANIM_RENDER_QUALITY=l

# Optional: max number of scenes the planner can produce
# MAX_SECTIONS=7
