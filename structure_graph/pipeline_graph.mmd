---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	parse(parse)
	planner(planner)
	step_descriptions(step_descriptions)
	code_gen(code_gen)
	scene_fix(scene_fix)
	render(render)
	__end__([<p>__end__</p>]):::last
	__start__ --> parse;
	code_gen --> scene_fix;
	parse -.-> __end__;
	parse -.-> planner;
	planner --> step_descriptions;
	scene_fix --> render;
	step_descriptions --> code_gen;
	render --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
